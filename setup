#!/usr/bin/env python3
"""
toprank setup — register skills with Claude Code, Codex, and/or OpenClaw.

Cross-platform (Windows, macOS, Linux).
Usage: ./setup [--host claude|codex|openclaw|auto] [--skill NAME] [--api-key KEY]
"""

import argparse
import json
import os
import platform
import shutil
import subprocess
import sys
import tempfile

TOPRANK_DIR = os.path.dirname(os.path.abspath(__file__))
TOPRANK_NAME = os.path.basename(TOPRANK_DIR)
SKILLS_DIR = os.path.dirname(TOPRANK_DIR)

# Subdirectories that contain skills (each subdir may hold multiple skill folders)
SKILL_CATEGORIES = ["seo", "google-ads"]


def parse_args():
    parser = argparse.ArgumentParser(description="Register toprank skills with your agent")
    parser.add_argument(
        "--host",
        choices=["claude", "codex", "openclaw", "auto"],
        default="auto",
        help="Target host (default: auto-detect)",
    )
    parser.add_argument(
        "--skill",
        default="",
        help="Only setup a single skill by name",
    )
    parser.add_argument(
        "--api-key",
        default="",
        help="API key for MCP server configuration",
    )
    return parser.parse_args()


def make_bin_executable():
    bin_dir = os.path.join(TOPRANK_DIR, "bin")
    if not os.path.isdir(bin_dir):
        return
    if platform.system() == "Windows":
        return  # Windows uses file associations, not executable bits
    for fname in os.listdir(bin_dir):
        fpath = os.path.join(bin_dir, fname)
        if os.path.isfile(fpath):
            try:
                os.chmod(fpath, os.stat(fpath).st_mode | 0o111)
            except OSError:
                pass


def discover_skills():
    """Find all skills and return (name, relative_path) tuples.

    Scans category subdirectories (seo/, google-ads/) and the root for
    directories containing a SKILL.md file.
    """
    skills = []

    # Scan category subdirectories
    for category in SKILL_CATEGORIES:
        cat_dir = os.path.join(TOPRANK_DIR, category)
        if not os.path.isdir(cat_dir):
            continue
        for entry in sorted(os.listdir(cat_dir)):
            skill_dir = os.path.join(cat_dir, entry)
            if os.path.isdir(skill_dir) and os.path.isfile(os.path.join(skill_dir, "SKILL.md")):
                rel_path = os.path.join(category, entry)
                skills.append((entry, rel_path))

    # Scan root level (for toprank-upgrade and any other root-level skills)
    for entry in sorted(os.listdir(TOPRANK_DIR)):
        skill_dir = os.path.join(TOPRANK_DIR, entry)
        if entry in SKILL_CATEGORIES:
            continue  # already scanned
        if os.path.isdir(skill_dir) and os.path.isfile(os.path.join(skill_dir, "SKILL.md")):
            skills.append((entry, entry))

    return skills


def inject_preamble(skills):
    preamble_file = os.path.join(TOPRANK_DIR, "bin", "preamble.md")
    if not os.path.isfile(preamble_file):
        return []

    with open(preamble_file) as f:
        preamble = f.read()

    injected = []
    for skill_name, rel_path in skills:
        if skill_name in ("toprank-upgrade", "ads"):
            continue
        skill_path = os.path.join(TOPRANK_DIR, rel_path, "SKILL.md")
        if not os.path.isfile(skill_path):
            continue
        with open(skill_path) as f:
            content = f.read()
        if "toprank-update-check" in content:
            continue

        parts = content.split("---", 2)
        if len(parts) < 3:
            continue

        new_content = parts[0] + "---" + parts[1] + "---\n\n" + preamble + parts[2].lstrip("\n")
        skill_dir_path = os.path.dirname(skill_path)
        fd, tmp_path = tempfile.mkstemp(dir=skill_dir_path)
        try:
            with os.fdopen(fd, "w") as f:
                f.write(new_content)
            os.replace(tmp_path, skill_path)
        except Exception:
            try:
                os.unlink(tmp_path)
            except OSError:
                pass
            raise
        injected.append(skill_name)

    return injected


def _symlink(src, dst):
    """Create symlink src->dst. Falls back to copy on Windows if symlinks fail."""
    if os.path.islink(dst):
        os.unlink(dst)

    try:
        os.symlink(src, dst)
        return "symlinked"
    except (OSError, NotImplementedError):
        full_src = src if os.path.isabs(src) else os.path.join(SKILLS_DIR, src)
        if platform.system() == "Windows":
            result = subprocess.run(
                ["cmd", "/c", "mklink", "/J", dst, full_src],
                capture_output=True,
            )
            if result.returncode == 0:
                return "junctioned"
        # Last resort: copy
        if os.path.isdir(full_src):
            shutil.copytree(full_src, dst)
        else:
            shutil.copy2(full_src, dst)
        return "copied"


def setup_claude(skills):
    print("Claude Code:")
    linked = []
    for skill_name, rel_path in skills:
        src = os.path.join(TOPRANK_NAME, rel_path)  # relative path for portability
        dst = os.path.join(SKILLS_DIR, skill_name)

        if os.path.exists(dst) and not os.path.islink(dst):
            print(f"  skipped {skill_name} (real directory exists at {dst})")
            continue

        method = _symlink(src, dst)
        linked.append(f"{skill_name} ({method})")

    if linked:
        print(f"  linked skills: {', '.join(linked)}")
        for skill_name, _ in skills:
            print(f"    -> {os.path.join(SKILLS_DIR, skill_name)}")
    else:
        print("  no new skills to link")


def setup_codex(skills):
    print("Codex:")
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, cwd=TOPRANK_DIR,
        )
        repo_root = result.stdout.strip() if result.returncode == 0 else ""
    except FileNotFoundError:
        repo_root = ""

    # If the git root IS the toprank directory itself, we're running from
    # within the toprank clone (e.g. ~/.claude/skills/toprank), not from a
    # user project.  Fall back to ~/.codex/skills/ so Codex can find them.
    if repo_root and os.path.realpath(repo_root) == os.path.realpath(TOPRANK_DIR):
        repo_root = ""

    agents_dir = (
        os.path.join(repo_root, ".agents", "skills")
        if repo_root
        else os.path.join(os.path.expanduser("~"), ".codex", "skills")
    )

    linked = []
    for skill_name, rel_path in skills:
        codex_skill_name = f"toprank-{skill_name}"
        codex_dir = os.path.join(agents_dir, codex_skill_name)
        os.makedirs(os.path.join(codex_dir, "agents"), exist_ok=True)

        # Read description from frontmatter
        skill_md = os.path.join(TOPRANK_DIR, rel_path, "SKILL.md")
        desc = f"Toprank {skill_name} skill"
        if os.path.isfile(skill_md):
            with open(skill_md) as f:
                content = f.read()
            in_desc = False
            desc_lines = []
            for line in content.splitlines():
                if line.startswith("description:"):
                    rest = line[len("description:"):].strip()
                    if rest and rest != ">":
                        desc = rest[:120]
                        break
                    in_desc = True
                elif in_desc:
                    if line.startswith("---") or (line and not line.startswith(" ")):
                        break
                    desc_lines.append(line.strip())
            if desc_lines:
                desc = " ".join(desc_lines)[:120]

        yaml_path = os.path.join(codex_dir, "agents", "openai.yaml")
        with open(yaml_path, "w") as f:
            f.write(f"""interface:
  display_name: "toprank-{skill_name}"
  short_description: "{desc}"
  default_prompt: "Use toprank-{skill_name} for this task."
policy:
  allow_implicit_invocation: true
""")

        # Copy SKILL.md and asset directories (not symlink — Codex rejects external symlinks)
        for asset in ["SKILL.md", "scripts", "references"]:
            asset_src = os.path.join(TOPRANK_DIR, rel_path, asset)
            asset_dst = os.path.join(codex_dir, asset)
            if not os.path.exists(asset_src):
                continue
            if os.path.islink(asset_dst):
                os.unlink(asset_dst)
            if os.path.isdir(asset_src):
                if os.path.exists(asset_dst):
                    shutil.rmtree(asset_dst)
                shutil.copytree(asset_src, asset_dst)
            else:
                shutil.copy2(asset_src, asset_dst)

        linked.append(codex_skill_name)

    if linked:
        print(f"  linked skills: {', '.join(linked)}")
        for codex_skill_name in linked:
            print(f"    -> {os.path.join(agents_dir, codex_skill_name)}")
    else:
        print("  no new skills to link")


def setup_openclaw(skills):
    """OpenClaw rejects symlinks that resolve outside the skills root, so we copy."""
    print("OpenClaw:")
    openclaw_skills = os.path.join(os.path.expanduser("~"), ".openclaw", "workspace", "skills")
    os.makedirs(openclaw_skills, exist_ok=True)

    installed = []
    for skill_name, rel_path in skills:
        src = os.path.join(TOPRANK_DIR, rel_path)
        dst = os.path.join(openclaw_skills, skill_name)
        if os.path.islink(dst):
            os.unlink(dst)
        os.makedirs(dst, exist_ok=True)
        for entry in os.listdir(src):
            s = os.path.join(src, entry)
            d = os.path.join(dst, entry)
            if os.path.isdir(s):
                if os.path.exists(d):
                    shutil.rmtree(d)
                shutil.copytree(s, d)
            else:
                shutil.copy2(s, d)
        installed.append(skill_name)

    if installed:
        print(f"  installed skills: {', '.join(installed)}")
        for skill_name in installed:
            print(f"    -> {os.path.join(openclaw_skills, skill_name)}")
    else:
        print("  no new skills to install")


def detect_hosts(host_arg):
    install_claude = False
    install_codex = False
    install_openclaw = False

    if host_arg == "claude":
        install_claude = True
    elif host_arg == "codex":
        install_codex = True
    elif host_arg == "openclaw":
        install_openclaw = True
    else:
        claude_skills = os.path.join(".claude", "skills")
        if SKILLS_DIR.endswith(claude_skills) or SKILLS_DIR.replace("\\", "/").endswith(claude_skills):
            install_claude = True
        if shutil.which("codex"):
            install_codex = True
        openclaw_skills = os.path.join(".openclaw", "workspace", "skills")
        if SKILLS_DIR.endswith(openclaw_skills) or SKILLS_DIR.replace("\\", "/").endswith(openclaw_skills):
            install_openclaw = True
        if shutil.which("openclaw"):
            install_openclaw = True
        if not install_claude and not install_codex and not install_openclaw:
            install_claude = True

    return install_claude, install_codex, install_openclaw


def _replace_key(obj, key):
    """Recursively replace ${ADS_AGENT_KEY} placeholders with the actual key."""
    if isinstance(obj, str):
        return obj.replace("${ADS_AGENT_KEY}", key)
    if isinstance(obj, list):
        return [_replace_key(v, key) for v in obj]
    if isinstance(obj, dict):
        return {k: _replace_key(v, key) for k, v in obj.items()}
    return obj


def setup_mcp(skills, api_key):
    """Configure MCP servers in Claude Desktop settings."""
    for skill_name, rel_path in skills:
        mcporter_path = os.path.join(TOPRANK_DIR, rel_path, "mcporter.json")
        if not os.path.isfile(mcporter_path):
            continue

        key = api_key
        if not key:
            config_path = os.path.join(os.path.expanduser("~"), ".adsagent", "config.json")
            if os.path.isfile(config_path):
                try:
                    with open(config_path) as f:
                        key = json.load(f).get("apiKey", "")
                except Exception:
                    pass
        if not key:
            continue

        with open(mcporter_path) as f:
            mcporter = json.load(f)

        new_servers = mcporter.get("mcpServers", {})
        if not new_servers:
            continue

        new_servers = _replace_key(new_servers, key)

        print("MCP servers:")
        configs_written = []

        system = platform.system()
        if system == "Darwin":
            desktop_config = os.path.join(
                os.path.expanduser("~"), "Library", "Application Support", "Claude", "claude_desktop_config.json"
            )
        elif system == "Linux":
            desktop_config = os.path.join(
                os.path.expanduser("~"), ".config", "Claude", "claude_desktop_config.json"
            )
        elif system == "Windows":
            desktop_config = os.path.join(os.environ.get("APPDATA", ""), "Claude", "claude_desktop_config.json")
        else:
            desktop_config = ""

        if desktop_config:
            os.makedirs(os.path.dirname(desktop_config), exist_ok=True)
            config = {}
            if os.path.isfile(desktop_config):
                with open(desktop_config) as f:
                    config = json.load(f)
            config.setdefault("mcpServers", {}).update(new_servers)
            with open(desktop_config, "w") as f:
                json.dump(config, f, indent=2)
            configs_written.append("Claude Desktop")

        if configs_written:
            print(f"  configured: {', '.join(configs_written)}")
            for name in new_servers:
                print(f"  + {name}")


def prompt_google_ads_setup(skills):
    """Interactively set up Google Ads if the user wants it and stdin is a TTY."""
    # Check if any skill has a mcporter.json (i.e., needs MCP config)
    has_ads = any(
        os.path.isfile(os.path.join(TOPRANK_DIR, rel_path, "mcporter.json"))
        for _, rel_path in skills
    )
    if not has_ads:
        return ""

    # Check if API key already exists
    config_path = os.path.join(os.path.expanduser("~"), ".adsagent", "config.json")
    if os.path.isfile(config_path):
        try:
            with open(config_path) as f:
                existing_key = json.load(f).get("apiKey", "")
            if existing_key:
                return existing_key  # Already configured
        except Exception:
            pass

    # Only prompt if stdin is a TTY (skip for piped installs)
    # TOPRANK_FORCE_INTERACTIVE=1 overrides the TTY check (for testing)
    if not sys.stdin.isatty() and not os.environ.get("TOPRANK_FORCE_INTERACTIVE"):
        return ""

    print()
    try:
        use_ads = input("Do you use Google Ads? (y/n): ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return ""

    if use_ads not in ("y", "yes"):
        return ""

    print()
    print("  Get your free API key at: https://www.adsagent.org")
    print()
    try:
        api_key = input("  Paste your API key: ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return ""

    if not api_key:
        return ""

    # Save the key
    config_dir = os.path.join(os.path.expanduser("~"), ".adsagent")
    os.makedirs(config_dir, exist_ok=True)
    with open(os.path.join(config_dir, "config.json"), "w") as f:
        json.dump({"apiKey": api_key}, f)
    print("  saved to ~/.adsagent/config.json")

    return api_key


def main():
    args = parse_args()

    print("toprank setup")
    print("─────────────")
    print()

    make_bin_executable()

    skills = discover_skills()
    if not skills:
        print("  no skills found")
        return

    if args.skill:
        match = [(name, rel) for name, rel in skills if name == args.skill]
        if not match:
            print(f"  skill '{args.skill}' not found", file=sys.stderr)
            sys.exit(1)
        skills = match

    injected = inject_preamble(skills)
    if injected:
        print(f"  injected preamble: {' '.join(injected)}")

    install_claude, install_codex, install_openclaw = detect_hosts(args.host)

    if install_claude:
        setup_claude(skills)
    if install_codex:
        setup_codex(skills)
    if install_openclaw:
        setup_openclaw(skills)

    # Google Ads API key: use --api-key flag, or prompt interactively
    api_key = args.api_key
    if api_key:
        config_dir = os.path.join(os.path.expanduser("~"), ".adsagent")
        os.makedirs(config_dir, exist_ok=True)
        with open(os.path.join(config_dir, "config.json"), "w") as f:
            json.dump({"apiKey": api_key}, f)
        print("  wrote ~/.adsagent/config.json")
    else:
        api_key = prompt_google_ads_setup(skills)

    setup_mcp(skills, api_key)

    seo_count = sum(1 for _, rel in skills if rel.startswith("seo/"))
    ads_count = sum(1 for _, rel in skills if rel.startswith("google-ads/"))
    print()
    print(f"Done. {seo_count} SEO skills and {ads_count} Google Ads skill(s) installed.")
    print("  Try: /seo-analysis or /ads")


if __name__ == "__main__":
    main()
